# Authenticated HTTP server with bearer token.
# Required for write-capable HTTP on non-local addresses.
# Replace <long-random-token> with a real secret.

export CONTAINER_RUNTIME_MCP_TRANSPORT=http
export CONTAINER_RUNTIME_MCP_HTTP_ADDR=0.0.0.0:8080
export CONTAINER_RUNTIME_MCP_HTTP_PATH=/mcp
export CONTAINER_RUNTIME_MCP_HTTP_AUTH_TOKEN=<long-random-token>
