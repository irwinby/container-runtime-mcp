# container-runtime-mcp example environment configuration
# Copy this file to .env and adjust values as needed.
# All variables use the CONTAINER_RUNTIME_ prefix.

# ------------------------------------------------------------------------------
# MCP Server Settings
# ------------------------------------------------------------------------------

# MCP implementation name reported to clients.
# Default: Container Runtime
# CONTAINER_RUNTIME_MCP_SERVER_NAME=Container Runtime

# MCP implementation title reported to clients.
# Default: (empty)
# CONTAINER_RUNTIME_MCP_SERVER_TITLE=

# MCP implementation version reported to clients.
# Default: 1.0.0
# CONTAINER_RUNTIME_MCP_SERVER_VERSION=1.0.0

# ------------------------------------------------------------------------------
# Transport Settings
# ------------------------------------------------------------------------------

# MCP transport mode.
# Supported values: stdio, http
# Default: stdio
# CONTAINER_RUNTIME_MCP_TRANSPORT=stdio

# HTTP listen address when transport is http.
# Default: 127.0.0.1:8080
# CONTAINER_RUNTIME_MCP_HTTP_ADDR=127.0.0.1:8080

# HTTP path prefix when transport is http. Must start with /.
# Default: /mcp
# CONTAINER_RUNTIME_MCP_HTTP_PATH=/mcp

# Idle session timeout for HTTP transport. Parsed as a Go duration.
# Default: 30m
# CONTAINER_RUNTIME_MCP_HTTP_SESSION_TIMEOUT=30m

# HTTP server read timeout. Parsed as a Go duration.
# Default: 10s
# CONTAINER_RUNTIME_MCP_HTTP_READ_TIMEOUT=10s

# HTTP server idle timeout. Parsed as a Go duration.
# Default: 120s
# CONTAINER_RUNTIME_MCP_HTTP_IDLE_TIMEOUT=120s

# Bearer token for HTTP transport authentication.
# Required for non-local addresses when CONTAINER_RUNTIME_MCP_READ_ONLY=false.
# Default: empty
# CONTAINER_RUNTIME_MCP_HTTP_AUTH_TOKEN=

# ------------------------------------------------------------------------------
# Operation Settings
# ------------------------------------------------------------------------------

# Timeout applied to runtime operations. Parsed as a Go duration (e.g. 30s, 5m, 1h).
# Must not be negative. A value of 0 disables the timeout.
# Default: 10m
# CONTAINER_RUNTIME_MCP_REMOTE_OPERATION_TIMEOUT=10m

# Read-only mode. When true, only read-only tools are registered.
# Default: false
# CONTAINER_RUNTIME_MCP_READ_ONLY=false

# ----------------------------------------------------------------------------
# Logging Settings
# ----------------------------------------------------------------------------

# Log level.
# Supported values: debug, info, warn, error
# Default: info
# CONTAINER_RUNTIME_LOG_LEVEL=info
